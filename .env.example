# ==============================================================================
# Open Crypto Tax — environment configuration
# Copy to .env, edit, then `npm run dev` (or `docker compose up`).
# ==============================================================================

# ---- Required ----------------------------------------------------------------

# Postgres. With docker-compose, this is set for you.
DATABASE_URL=postgres://octax:octax@localhost:5432/octax

# Cookie secret for sessions. Change this in production.
SESSION_SECRET=please-change-me-to-a-long-random-string

# ---- Auth --------------------------------------------------------------------

# AUTH_MODE=local: single-user, no Firebase needed. Easiest self-host.
# AUTH_MODE=firebase: multi-user via Google sign-in.
# Default: local if no Firebase env vars are set, else firebase.
AUTH_MODE=local
LOCAL_USER_ID=local-user
LOCAL_USER_EMAIL=you@localhost

# Only needed if AUTH_MODE=firebase
# FIREBASE_PROJECT_ID=
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# ---- Frontend ----------------------------------------------------------------

# Match the server. Set VITE_AUTH_MODE=local to skip Firebase init in the browser.
VITE_AUTH_MODE=local

# Only needed if VITE_AUTH_MODE=firebase
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# ---- External services (optional) -------------------------------------------

# Alchemy — required to sync EVM wallet transactions. Sign up at alchemy.com.
# ALCHEMY_API_KEY=

# Telegram bot — optional, for push notifications and classify-by-reply.
# Create a bot via @BotFather on Telegram.
# TELEGRAM_BOT_TOKEN=

# ---- Server ------------------------------------------------------------------

PORT=5000
NODE_ENV=development
